# ─────────────────────────────────────────────────────────────
# AI Image World — root .gitignore (monorepo: client + server)
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.js

# Environment / secrets — NEVER commit real .env files
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Build output
dist/
build/
**/dist/
**/build/
.vite/

# Local image uploads (Cloudinary dev fallback)
server/uploads/*
!server/uploads/.gitignore

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# Caches
.cache/
.eslintcache
.parcel-cache/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Misc runtime
*.pid
*.seed
tmp/
temp/
