{
  "name": "ai-image-world-server",
  "version": "1.0.0",
  "description": "Backend API for AI Image World — MERN stack (Express, MongoDB, JWT, Cloudinary)",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "dev:memory": "cross-env NODE_ENV=development USE_MEMORY_DB=true nodemon src/server.js",
    "seed": "node src/seed/seed.js",
    "seed:admin": "node src/seed/seedSuperAdmin.js",
    "seed:content": "node src/seed/seedContent.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "ai",
    "images",
    "prompts",
    "mern",
    "express",
    "mongodb"
  ],
  "author": "AI Image World",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.5.1",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.4.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "express-rate-limit": "^7.4.0",
    "morgan": "^1.10.0",
    "winston": "^3.13.1",
    "slugify": "^1.6.6",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "mongodb-memory-server": "^10.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "cross-env": "^7.0.3"
  }
}
