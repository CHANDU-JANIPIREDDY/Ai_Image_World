# ─────────────────────────────────────────────────────────────
# AI Image World — Backend Environment Variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/ai_image_world

# JWT — generate strong random secrets (min 32 chars) for production
# e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_ACCESS_SECRET=replace_with_strong_random_32+_char_secret
JWT_REFRESH_SECRET=replace_with_different_strong_32+_char_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary (Phase 5) — required in production
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — comma-separated allowed client origins
# Production example: https://ai-image-world.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Optional cache/queue
# REDIS_URL=redis://127.0.0.1:6379

# ─────────────────────────────────────────────────────────────
# Seeding — initial superadmin (npm run seed:admin / seed:content)
# In production these are REQUIRED for seeding (the default password is
# refused when NODE_ENV=production).
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@aiimageworld.com
# Use a strong password in production (8+ chars, 1 uppercase, 1 number).
SEED_ADMIN_PASSWORD=Admin@12345

# ─────────────────────────────────────────────────────────────
# Production checklist
#  • NODE_ENV=production
#  • Strong, unique JWT secrets (32+ chars each)
#  • Real Cloudinary credentials (uploads fail without them)
#  • MONGO_URI → MongoDB Atlas (allow Render egress IPs / 0.0.0.0)
#  • CLIENT_ORIGIN → your deployed frontend origin (enables secure cookies)
# ─────────────────────────────────────────────────────────────
