# ─────────────────────────────────────────────────────────────
# AI Image World — Frontend Environment Variables (Vite)
# Copy to `.env` (or `.env.local`) and adjust.
# Only variables prefixed with VITE_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Absolute base URL of the backend API (include the /api/v1 suffix).
# In local dev you can leave this blank — Vite proxies /api to localhost:5000.
# In production (Vercel), set it to your deployed backend, e.g.:
#   VITE_API_URL=https://ai-image-world-api.onrender.com/api/v1
VITE_API_URL=
